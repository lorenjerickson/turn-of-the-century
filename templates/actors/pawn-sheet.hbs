<form class="{{cssClass}} totc-actor-sheet" autocomplete="off">
    <header class="sheet-header">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="104" width="104" />
        <section class="header-fields">
            <h1 class="charname">
                <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
            </h1>
            <div class="actor-subtitle">
                <span>{{localize "TOTC.Actor.Type"}}: {{actor.type}}</span>
                <span>{{localize "TOTC.Actor.Category"}}: {{system.classification.category}}</span>
                <span>{{localize "TOTC.Actor.Level"}}: {{system.progression.level}}</span>
            </div>
        </section>
    </header>

    <section class="sheet-body sheet-body--sidebar">
        <aside class="sheet-sidebar">
            <section class="totc-ability-scores">
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.str.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortStr"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.str.bonus decimals=0 sign=true}}</div>
                </div>
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.dex.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortDex"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.dex.bonus decimals=0 sign=true}}</div>
                </div>
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.con.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortCon"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.con.bonus decimals=0 sign=true}}</div>
                </div>
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.int.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortInt"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.int.bonus decimals=0 sign=true}}</div>
                </div>
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.wis.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortWis"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.wis.bonus decimals=0 sign=true}}</div>
                </div>
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.cha.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortCha"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.cha.bonus decimals=0 sign=true}}</div>
                </div>
                <div class="totc-ability-score">
                    <div class="totc-ability-score__value">{{system.abilities.san.value}}</div>
                    <div class="totc-ability-score__label">{{localize "TOTC.Actor.Ability.ShortSan"}}</div>
                    <div class="totc-ability-score__modifier">{{numberFormat system.abilities.san.bonus decimals=0 sign=true}}</div>
                </div>
            </section>
        </aside>

        <main class="sheet-main">
            <nav class="sheet-tabs tabs" data-group="primary">
                <a class="item" data-tab="profile">{{localize "TOTC.Sheet.Profile"}}</a>
                <a class="item" data-tab="inventory">{{localize "TOTC.Sheet.Inventory"}}</a>
                <a class="item" data-tab="identity">{{localize "TOTC.Actor.Identity"}}</a>
                <a class="item" data-tab="pawn">{{localize "TOTC.Actor.TypeDetails"}}</a>
            </nav>

            <div class="tab profile" data-group="primary" data-tab="profile">
                <div class="totc-two-column">
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Profession"}}</label>
                        <input name="system.classification.profession" type="text" value="{{system.classification.profession}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Origin"}}</label>
                        <input name="system.classification.origin" type="text" value="{{system.classification.origin}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Faction"}}</label>
                        <input name="system.profile.faction" type="text" value="{{system.profile.faction}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Role"}}</label>
                        <input name="system.profile.role" type="text" value="{{system.profile.role}}" />
                    </div>
                </div>
                <div class="form-group stacked">
                    <label>{{localize "TOTC.Actor.ProfileSummary"}}</label>
                    <textarea name="system.profile.summary" rows="3">{{system.profile.summary}}</textarea>
                </div>
                <div class="form-group stacked">
                    <label>{{localize "TOTC.Actor.Tags"}}</label>
                    <input name="_array.system.profile.tags" type="text" value="{{profileTags}}" placeholder="minion, city-watch, factory" />
                </div>
                <div class="form-group stacked">
                    <label>{{localize "TOTC.Actor.Biography"}}</label>
                    {{editor system.biography target="system.biography" button=true owner=owner editable=editable}}
                </div>
                <div class="form-group stacked">
                    <label>{{localize "TOTC.Actor.Notes"}}</label>
                    {{editor system.notes target="system.notes" button=true owner=owner editable=editable}}
                </div>
                <section class="totc-equipment-section">
                    <h2>{{localize "TOTC.Actor.Equipment"}}</h2>
                    <div class="totc-equipment-grid">
                        {{#each equipmentSlots as |slot|}}
                            <div class="totc-equipment-slot">
                                <div class="totc-equipment-slot__header">
                                    <span class="totc-equipment-slot__label">{{slot.label}}</span>
                                    <span class="totc-equipment-slot__meta">{{localize "TOTC.Actor.Equipment.Allowed"}}: {{slot.allowedSummary}}</span>
                                </div>
                                {{#if slot.isBelt}}
                                    <div class="totc-equipment-slot__quality">
                                        <label>{{localize "TOTC.Actor.Equipment.BeltQuality"}}</label>
                                        <select name="system.inventory.equipment.belt.quality">
                                            {{#each slot.qualityOptions as |qualityOption|}}
                                                <option value="{{qualityOption.value}}" {{#if (eq qualityOption.value slot.quality)}}selected{{/if}}>{{qualityOption.label}}</option>
                                            {{/each}}
                                        </select>
                                        <span class="totc-equipment-slot__meta">{{localize "TOTC.Actor.Equipment.Capacity"}}: {{slot.capacity}}</span>
                                    </div>
                                {{/if}}
                                <div class="totc-equipment-slot__positions">
                                    {{#each slot.positions as |position|}}
                                        <label class="totc-equipment-slot__position">
                                            {{#if (gt slot.capacity 1)}}
                                                <span>{{position.label}}</span>
                                            {{/if}}
                                            <select name="{{position.fieldName}}">
                                                <option value="">{{localize "TOTC.Actor.Equipment.None"}}</option>
                                                {{#each position.options as |option|}}
                                                    <option value="{{option.id}}" {{#if (eq option.id position.selectedItemId)}}selected{{/if}} {{#if option.disabled}}disabled{{/if}}>{{option.name}} ({{option.type}})</option>
                                                {{/each}}
                                            </select>
                                        </label>
                                    {{/each}}
                                </div>
                                {{#unless slot.hasOptions}}
                                    <p class="totc-equipment-slot__empty">{{localize "TOTC.Actor.Equipment.Empty"}}</p>
                                {{/unless}}
                            </div>
                        {{/each}}
                    </div>
                </section>
                <section class="totc-pack-section">
                    <h2>{{localize "TOTC.Actor.Pack"}}</h2>
                    {{#if packItems.length}}
                        <div class="totc-pack-items">
                            {{#each packItems as |item|}}
                                <div class="totc-pack-item" draggable="true" data-item-id="{{item.id}}">
                                    <img class="totc-pack-item__img" src="{{item.img}}" alt="{{item.name}}" />
                                    <div class="totc-pack-item__details">
                                        <span class="totc-pack-item__name">{{item.name}}</span>
                                        <span class="totc-pack-item__type">{{item.type}}</span>
                                    </div>
                                    <button class="totc-pack-item__delete" type="button" data-item-id="{{item.id}}" title="{{localize 'TOTC.Actor.Pack.Delete'}}">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            {{/each}}
                        </div>
                    {{else}}
                        <p class="totc-pack-empty">{{localize "TOTC.Actor.Pack.Empty"}}</p>
                    {{/if}}
                </section>
            </div>

            <div class="tab inventory" data-group="primary" data-tab="inventory">
                <section class="totc-inventory-group">
                    <h2>{{localize "TOTC.Actor.Equipment"}}</h2>
                    <div class="totc-inventory-slots">
                        {{#each inventorySummary.equippedBySlot as |slot|}}
                            <div class="totc-inventory-slot">
                                <div class="totc-inventory-slot__label">{{slot.label}}</div>
                                {{#if slot.equippedItems.length}}
                                    <ul class="totc-inventory-items">
                                        {{#each slot.equippedItems as |item|}}
                                            <li class="totc-inventory-item">
                                                <img src="{{item.img}}" alt="{{item.name}}" />
                                                <span>{{item.name}} ({{item.type}})</span>
                                            </li>
                                        {{/each}}
                                    </ul>
                                {{else}}
                                    <p class="totc-equipment-slot__empty">{{localize "TOTC.Actor.Equipment.None"}}</p>
                                {{/if}}
                            </div>
                        {{/each}}
                    </div>
                </section>

                <section class="totc-inventory-group">
                    <h2>{{localize "TOTC.Actor.Pack"}}</h2>
                    {{#if inventorySummary.packItems.length}}
                        <ul class="totc-inventory-items">
                            {{#each inventorySummary.packItems as |item|}}
                                <li class="totc-inventory-item">
                                    <img src="{{item.img}}" alt="{{item.name}}" />
                                    <span>{{item.name}} ({{item.type}})</span>
                                </li>
                            {{/each}}
                        </ul>
                    {{else}}
                        <p class="totc-equipment-slot__empty">{{localize "TOTC.Actor.Pack.Empty"}}</p>
                    {{/if}}
                </section>

                <section class="totc-inventory-group">
                    <h2>{{localize "TOTC.Actor.Inventory.Unassigned"}}</h2>
                    {{#if inventorySummary.otherItems.length}}
                        <ul class="totc-inventory-items">
                            {{#each inventorySummary.otherItems as |item|}}
                                <li class="totc-inventory-item">
                                    <img src="{{item.img}}" alt="{{item.name}}" />
                                    <span>{{item.name}} ({{item.type}})</span>
                                </li>
                            {{/each}}
                        </ul>
                    {{else}}
                        <p class="totc-equipment-slot__empty">{{localize "TOTC.Actor.Inventory.None"}}</p>
                    {{/if}}
                </section>
            </div>

            <div class="tab identity" data-group="primary" data-tab="identity">
                <div class="totc-two-column">
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Species"}}</label>
                        <input name="system.classification.species" type="text" value="{{system.classification.species}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Ancestry"}}</label>
                        <input name="system.classification.ancestry" type="text" value="{{system.classification.ancestry}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Size"}}</label>
                        <select name="system.classification.size">
                            <option value="tiny" {{#if (eq system.classification.size "tiny")}}selected{{/if}}>{{localize "TOTC.Actor.SizeTiny"}}</option>
                            <option value="sm" {{#if (eq system.classification.size "sm")}}selected{{/if}}>{{localize "TOTC.Actor.SizeSmall"}}</option>
                            <option value="med" {{#if (eq system.classification.size "med")}}selected{{/if}}>{{localize "TOTC.Actor.SizeMedium"}}</option>
                            <option value="lg" {{#if (eq system.classification.size "lg")}}selected{{/if}}>{{localize "TOTC.Actor.SizeLarge"}}</option>
                            <option value="huge" {{#if (eq system.classification.size "huge")}}selected{{/if}}>{{localize "TOTC.Actor.SizeHuge"}}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Level"}}</label>
                        <input name="system.progression.level" type="number" value="{{system.progression.level}}" min="0" step="1" />
                    </div>
                </div>
            </div>

            <div class="tab pawn" data-group="primary" data-tab="pawn">
                <div class="totc-two-column">
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Pawn.Role"}}</label>
                        <input name="system.pawn.role" type="text" value="{{system.pawn.role}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Pawn.Threat"}}</label>
                        <input name="system.pawn.threat" type="number" value="{{system.pawn.threat}}" min="0" max="10" step="1" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Pawn.Disposition"}}</label>
                        <input name="system.pawn.disposition" type="text" value="{{system.pawn.disposition}}" />
                    </div>
                    <div class="form-group">
                        <label>{{localize "TOTC.Actor.Pawn.Squad"}}</label>
                        <input name="system.pawn.squad" type="text" value="{{system.pawn.squad}}" />
                    </div>
                </div>
            </div>
        </main>
    </section>
</form>
